{
  "name": "debt-freedom-planner-browser-tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./static_src/tailwind.css -o ./static/css/site.css --minify",
    "watch:css": "tailwindcss -i ./static_src/tailwind.css -o ./static/css/site.css --watch",
    "qa:playwright": "node tests/playwright-smoke.mjs",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "tailwindcss": "^3.4.17"
  }
}
